VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Domains (see docs/custom-domains.md) ─────────────────────
# melosoftapp.com's apex/www already belong to a DIFFERENT, older app —
# never point these at the bare apex. This app owns only the "commerce"
# subdomain and, once the wildcard is live, every {slug} subdomain.

# Origin of THIS admin panel. Also the fallback Wompi checkout redirect
# base when a store isn't being viewed through its own subdomain yet
# (e.g. dev, or prod before VITE_STOREFRONT_ROOT_DOMAIN is set).
VITE_PUBLIC_SITE_URL=https://commerce.melosoftapp.com

# Set this ONLY once *.melosoftapp.com wildcard DNS + the wildcard TLS
# certificate are verified working in the hosting provider. Setting it
# is what switches getPlatformStoreUrl() to {slug}.melosoftapp.com and
# turns on the automatic /s/:slug → subdomain redirect. Leave unset
# during the transition — /s/:slug keeps working either way.
VITE_STOREFRONT_ROOT_DOMAIN=melosoftapp.com

# Extra hostnames (besides VITE_PUBLIC_SITE_URL's own host and every
# reserved subdomain of VITE_STOREFRONT_ROOT_DOMAIN, which are already
# treated as platform hosts automatically) that must never be resolved
# as a store. Usually redundant with the two vars above; kept explicit
# for defense in depth.
VITE_PLATFORM_HOSTNAMES=commerce.melosoftapp.com

# Meta App ID and WhatsApp Embedded Signup Configuration ID — both public
# identifiers, never secrets. See docs/whatsapp/deployment.md.
VITE_META_APP_ID=
VITE_META_WHATSAPP_CONFIG_ID=
